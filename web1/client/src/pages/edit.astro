---
import Layout from "../layouts/Layout.astro";
import { personApi } from "../lib/api";
import PersonForm from "../components/PersonForm.astro";

export const prerender = false;
const { searchParams } = Astro.url;
const id = searchParams.get("id");

if (!id) {
  return Astro.redirect("/");
}

let person;
try {
  person = await personApi.findById(id);
} catch (e) {
  return Astro.redirect("/");
}
---

<Layout>
  <div class="mx-auto max-w-2xl p-8">
    <div class="mb-6">
      <a href="/" class="btn btn-ghost btn-sm mb-4">← Back to List</a>
      <h1 class="text-primary text-3xl font-bold">Edit Person</h1>
    </div>
    {person && <PersonForm person={person} />}
  </div>

  <script>
    import { personApi } from "../lib/api";

    const form = document.getElementById("personForm") as HTMLFormElement;
    const phoneList = document.getElementById("phoneList")!;
    const addPhoneBtn = document.getElementById("addPhone")!;

    const attachRemoveEvent = (btn: HTMLButtonElement) => {
      btn.addEventListener("click", () => btn.parentElement?.remove());
    };

    document
      .querySelectorAll(".remove-phone")
      .forEach((btn) => attachRemoveEvent(btn as HTMLButtonElement));

    addPhoneBtn.addEventListener("click", () => {
      const div = document.createElement("div");
      div.className = "flex gap-2";
      div.innerHTML = `
        <input type="text" placeholder="Number" class="input input-bordered flex-1 phone-number" required minlength="5" maxlength="20" />
        <input type="text" placeholder="Region" class="input input-bordered w-24 phone-region" required minlength="2" maxlength="2" />
        <input type="text" placeholder="Type" class="input input-bordered w-32 phone-type" required />
        <button type="button" class="btn btn-square btn-error remove-phone">✕</button>
      `;
      phoneList.appendChild(div);
      attachRemoveEvent(
        div.querySelector(".remove-phone") as HTMLButtonElement,
      );
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      const phones = Array.from(phoneList.children).map((child) => ({
        number: (child.querySelector(".phone-number") as HTMLInputElement)
          .value,
        region: (child.querySelector(".phone-region") as HTMLInputElement)
          .value,
        type: (child.querySelector(".phone-type") as HTMLInputElement).value,
      }));

      const person = {
        id: formData.get("id") as string,
        name: formData.get("name") as string,
        email: formData.get("email") as string,
        birthDate: formData.get("birthDate") as string,
        phones,
        properties: {},
      };

      try {
        await personApi.update(person);
        window.location.href = "/";
      } catch (err) {
        alert("Error updating person: " + err);
      }
    });
  </script>
</Layout>
