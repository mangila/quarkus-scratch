---
import Layout from "../layouts/Layout.astro";
import { personApi } from "../lib/api";
import PersonList from "../components/PersonList.vue";

const { searchParams } = Astro.url;
const page = parseInt(searchParams.get("page") || "0");
const size = 10;

let personsPage;
let error = "";

try {
  personsPage = await personApi.findPage(page, size);
} catch (e) {
  console.error(e);
  error = "Failed to load persons. Is the API running?";
}
---

<Layout>
  <PersonList
    client:load
    initialPersonsPage={personsPage}
    initialPage={page}
    pageSize={size}
  />
</Layout>
