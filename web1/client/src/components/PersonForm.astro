---
let { person } = Astro.props;

person ??= {
  id: '',
  name: '',
  email: '',
  birthDate: '',
  phones: []
}
---

<form id="personForm" class="bg-base-100 p-6 rounded-lg shadow space-y-4">
      <input type="hidden" name="id" value={person.id} />

      <div class="form-control">
        <label class="label"><span class="label-text">Name</span></label>
        <input type="text" name="name" value={person.name} required class="input input-bordered" minlength="2" maxlength="32" />
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">Email</span></label>
        <input type="email" name="email" value={person.email} required class="input input-bordered" />
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">Birth Date</span></label>
        <input type="date" name="birthDate" value={person.birthDate} required class="input input-bordered" />
      </div>

      <div class="divider">Phones</div>
      <div id="phoneList" class="space-y-2">
        {person.phones.map((phone, index) => (
          <div class="flex gap-2">
            <input type="text" placeholder="Number" value={phone.number} class="input input-bordered flex-1 phone-number" required minlength="5" maxlength="20" />
            <input type="text" placeholder="Region" value={phone.region} class="input input-bordered w-24 phone-region" required minlength="2" maxlength="2" />
            <input type="text" placeholder="Type" value={phone.type} class="input input-bordered w-32 phone-type" required />
            {index > 0 && <button type="button" class="btn btn-square btn-error remove-phone">✕</button>}
          </div>
        ))}
      </div>
      <button type="button" id="addPhone" class="btn btn-xs btn-outline mt-2">Add Another Phone</button>

      <div class="pt-6">
        <button type="submit" class="btn btn-primary w-full">Submit Person</button>
      </div>
</form>